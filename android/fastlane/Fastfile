default_platform(:android)

platform :android do

  desc "Set versionCode and versionName from Google Play internal track"
  lane :set_version do
    # version_codes = google_play_track_version_codes(
    #   package_name: CredentialsManager::AppfileConfig.try_fetch_value(:package_name),
    #   track: "internal",
    #   json_key: CredentialsManager::AppfileConfig.try_fetch_value(:json_key_file)
    # )
    version_codes = []

    begin
    version_codes = google_play_track_version_codes(
      track: "internal"
    )
    rescue => e
      UI.message("No existing version found on Play Store (first release)")
    end

  new_version_code = (version_codes.max || 0) + 1

  UI.message("New Version Code: #{new_version_code}")

    # Increment the highest existing version code by 1
    version_code = new_version_code
    version_name = "1.0.#{version_code}"

    UI.message("Latest Play Store versionCode: #{version_code || 'none'}")
    UI.message("Setting versionCode=#{version_code}, versionName=#{version_name}")
    
    android_set_version_code(
      version_code: version_code,
      gradle_file: "app/build.gradle"
    )

    android_set_version_name(
      version_name: version_name,
      gradle_file: "app/build.gradle"
    )
  end

  desc "Build release AAB"
  lane :build do
    gradle(
      task: "bundle",
      build_type: "Release"
    )
  end

  # 🔹 Internal testing
  desc "Set version and build for internal testing"
  lane :internal do
    set_version
    build
    # upload_to_play_store(
    #   track: "internal",
    #   aab: "app/build/outputs/bundle/release/app-release.aab"
    # )
  end

  # 🔹 Production (direct upload - not recommended usually)
  # lane :production do
  #   upload_to_play_store(
  #     track: "production",
  #     aab: "app/build/outputs/bundle/release/app-release.aab"
  #   )
  # end

  # 🔹 BEST: Promote existing build to production
  # lane :promote do
  #   supply(
  #     track: "internal",
  #     track_promote_to: "production",
  #     rollout: 0.1
  #   )
  # end

  desc "Set version, build, and deploy"
  lane :deploy do
    set_version
    build
  end
end